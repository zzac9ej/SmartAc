## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Release]/
[Releases]/
x64/
x86/
build/
bld/
[Bin]/
[Obj]/
[Log]/
[Logs]/
bin/
obj/

# Visual Studio 2015/2017 cache directory
.vs/
# Generated user file
*.csproj.user

# CoreCLR debugger generate files
NUMERICS_NT.DAT

# MSBuild auto-generated cache files
*.nuget.cache
# exclude recovery files cherished by SCM
!*nuget.cache.lock

# Directories NuGet puts its packages in
packages/
# or obj/nuget.packages.tags.json
project.assets.json
project.lock.json

# Rider
.idea/

# AppSettings (prevent pushing secrets)
appsettings.json
